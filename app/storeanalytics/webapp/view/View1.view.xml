<mvc:View controllerName="com.demo.storeanalytics.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" xmlns:viz="sap.viz.ui5.controls"  xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
    <Page id="page" title="{i18n>title}">

    <content>

        <Text id="_IDGenText" text="My Store Analytics" class="sapMH3FontSize sapUiTinyMarginTop" width="100%" textAlign="Center" ></Text>
<l:Grid id="_IDGenGrid" defaultSpan="XL12 L12 M12 S12" xmlns:l="sap.ui.layout">
<FlexBox id="_IDGenFlexBox" justifyContent="SpaceAround" >
      <viz:VizFrame id="StoreWiseSales" vizType="donut" height="280px" >
    <viz:dataset>
   <viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{/StoreWiseSales}" >
   <viz.data:dimensions>
  <viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="storName" value="{storName}"></viz.data:DimensionDefinition>
   </viz.data:dimensions>
   <viz.data:measures>
   <viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="totalSales" value="{totalSales}" ></viz.data:MeasureDefinition>
   </viz.data:measures>
   </viz.data:FlattenedDataset>
    </viz:dataset>
    <viz:feeds>
    <viz.feeds:FeedItem id="_IDGenFeedItem" uid="size" type="Measure" values="totalSales" ></viz.feeds:FeedItem>
    <viz.feeds:FeedItem id="_IDGenFeedItem2" uid="color" type="Dimension" values="storName" ></viz.feeds:FeedItem>
 
    </viz:feeds>
    </viz:VizFrame>

      <!-- Product wise sales  -->
 
 
<viz:VizFrame id="ProductWiseSales" vizType="donut" height="280px" >
    <viz:dataset>
   <viz.data:FlattenedDataset id="_IDGenFlattenedDataset2" data="{/ProductWiseSales}" >
   <viz.data:dimensions>
  <viz.data:DimensionDefinition id="_IDGenDimensionDefinition1" name="productName" value="{productName}"></viz.data:DimensionDefinition>
   </viz.data:dimensions>
   <viz.data:measures>
   <viz.data:MeasureDefinition id="_IDGenMeasureDefinition1" name="totalSales" value="{totalSales}" ></viz.data:MeasureDefinition>
   </viz.data:measures>
   </viz.data:FlattenedDataset>
    </viz:dataset>
    <viz:feeds>
    <viz.feeds:FeedItem id="_IDGenFeedItem1" uid="size" type="Measure" values="totalSales" ></viz.feeds:FeedItem>
    <viz.feeds:FeedItem id="_IDGenFeedItem3" uid="color" type="Dimension" values="productName" ></viz.feeds:FeedItem>
 
    </viz:feeds>
    </viz:VizFrame>

    </FlexBox>


     
<FlexBox id="_IDGenFlexBox2" justifyContent="SpaceAround" >
 
    <viz:VizFrame id="LowStockProducts" vizType="bar" height="280px" >
    <viz:dataset>
   <viz.data:FlattenedDataset id="_IDGenFlattenedDataset1" data="{/LowStockProducts}" >
   <viz.data:dimensions>
  <viz.data:DimensionDefinition id="_IDGenDimensionDefinition2" name="name" value="{name}"></viz.data:DimensionDefinition>
   </viz.data:dimensions>
   <viz.data:measures>
   <viz.data:MeasureDefinition id="_IDGenMeasureDefinition2" name="stock" value="{stock}" ></viz.data:MeasureDefinition>
   </viz.data:measures>
   </viz.data:FlattenedDataset>
    </viz:dataset>
    <viz:feeds>
    <viz.feeds:FeedItem id="_IDGenFeedItem4" uid="valueAxis" type="Measure" values="stock" ></viz.feeds:FeedItem>
    <viz.feeds:FeedItem id="_IDGenFeedItem5" uid="categoryAxis" type="Dimension" values="name" ></viz.feeds:FeedItem>
 
    </viz:feeds>
    </viz:VizFrame>
 
 
    <!-- Product wise sales  -->
 
 
<viz:VizFrame id="Top3Orders" vizType="column" height="280px" >
    <viz:dataset>
   <viz.data:FlattenedDataset id="_IDGenFlattenedDataset3" data="{/Top3Orders}" >
   <viz.data:dimensions>
  <viz.data:DimensionDefinition id="_IDGenDimensionDefinition3" name="ID" value="{ID}"></viz.data:DimensionDefinition>
   </viz.data:dimensions>
   <viz.data:measures>
   <viz.data:MeasureDefinition id="_IDGenMeasureDefinition3" name="netPrice" value="{netPrice}" ></viz.data:MeasureDefinition>
   </viz.data:measures>
   </viz.data:FlattenedDataset>
    </viz:dataset>
    <viz:feeds>
    <viz.feeds:FeedItem id="_IDGenFeedItem6" uid="valueAxis" type="Measure" values="netPrice" ></viz.feeds:FeedItem>
    <viz.feeds:FeedItem id="_IDGenFeedItem7" uid="categoryAxis" type="Dimension" values="ID" ></viz.feeds:FeedItem>
 
    </viz:feeds>
    </viz:VizFrame>
 
</FlexBox>

 
</l:Grid>
    </content>
    </Page>
</mvc:View>